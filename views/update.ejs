<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Update Task</title>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>
  <%- include('navbar') %>

  <div class="page-wrapper">
    <p class="eyebrow">Editing task</p>
    <h1 class="page-title">Update your <em>task</em></h1>
    <p class="page-subtitle">Make your changes below.</p>

    <div class="form-card">
      <form action="/update/<%= result._id %>" method="post">
        <div class="field">
          <label>Task title</label>
          <input type="text" name="title" value="<%= result.title %>" required/>
        </div>
        <div class="field">
          <label>Description</label>
          <textarea name="description"><%= result.description %></textarea>
        </div>
        <button type="submit" class="btn-primary">Save changes</button>
      </form>
    </div>
  </div>
</body>
</html>
